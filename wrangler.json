{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "hokweb",
  "main": "./workers/app.ts",
  "compatibility_date": "2025-10-08",
  "compatibility_flags": ["nodejs_compat"],
  "minify": true,
  "tsconfig": "./tsconfig.json",
  "workers_dev": false,
  "preview_urls": false,
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1,
    "logs": {
      "enabled": true,
      "head_sampling_rate": 1,
      "persist": true,
      "invocation_logs": true
    },
    "traces": {
      "enabled": false,
      "persist": true,
      "head_sampling_rate": 1
    }
  },
  "routes": [
    {
      "pattern": "houseofknowledge.net/*",
      "zone_id": "257565acd67f73f5f829c8dc09093234"
    },
    {
      "pattern": "www.houseofknowledge.net/*",
      "zone_id": "257565acd67f73f5f829c8dc09093234"
    }
  ],
  "kv_namespaces": [
    {
      "binding": "CONTACTS_KV",
      "id": "75b4398cce344c0991d29264ffbfd670"
    }
  ],
  "d1_databases": [
    {
      "binding": "CONTACTS_DB",
      "database_name": "contacts",
      "database_id": "ab976bc5-ae50-443f-8b1b-0da3112e3b48"
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "name": "CONTACTS_DO",
        "class_name": "Contacts"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": [
        "Contacts"
      ]
    }
  ],
  "assets": {
    "directory": "./build/client",
    "run_worker_first": false
  },
  "upload_source_maps": true,
  "vars": {
    "VALUE_FROM_CLOUDFLARE": "House Of Knowledge",
    "MIGRATE_TOKEN": "migrate-temp-4f3b7c"
  }
}
